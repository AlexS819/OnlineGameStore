<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sochka.onlinegamestore.controller.RegistrationController"
           stylesheets="@../styles/style.css"
           prefWidth="800.0" prefHeight="600.0">

    <VBox alignment="CENTER" maxWidth="420.0" spacing="25" styleClass="login-panel">
        
        <VBox alignment="CENTER" spacing="5">
            <Label text="Join the Store" styleClass="header-text"/>
            <Label text="Provision new identity container" styleClass="sub-header-text"/>
        </VBox>

        <!-- Logical Entry Block -->
        <VBox spacing="15">
            <VBox spacing="5">
                <Label text="Public Name" styleClass="label-input"/>
                <TextField fx:id="nameField" promptText="e.g. John Doe"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Secured Email" styleClass="label-input"/>
                <TextField fx:id="emailField" promptText="name@provider.com"/>
            </VBox>
            
            <VBox spacing="5">
                <Label text="Unique Password" styleClass="label-input"/>
                <PasswordField fx:id="passwordField" promptText="Min 6 characters..."/>
            </VBox>
        </VBox>

        <Label fx:id="errorLabel" text="" styleClass="message-label" style="-fx-text-fill: #E74C3C;"/>

        <VBox alignment="CENTER" spacing="12">
            <Button fx:id="registerBtn" text="Initialize Account" maxWidth="Infinity" styleClass="primary-button"/>
            <Button fx:id="backToLoginBtn" text="Back to Identification" style="-fx-background-color: transparent; -fx-text-fill: #1877F2; -fx-cursor: hand;"/>
        </VBox>

    </VBox>
</StackPane>
