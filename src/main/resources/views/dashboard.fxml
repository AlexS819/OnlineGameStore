<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sochka.onlinegamestore.controller.DashboardController"
            stylesheets="@../styles/style.css"
            prefWidth="1366.0" prefHeight="768.0">

    <!-- Sidebar Navigation -->
    <left>
        <VBox prefWidth="220.0" spacing="5.0" styleClass="sidebar">
            <Label text="GS Manager" styleClass="sidebar-logo"/>
            <Separator opacity="0.1" />
            
            <Button fx:id="gameCatalogBtn" text="Game Catalog" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="keyInventoryBtn" text="Key Inventory" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="publishersBtn" text="Publishers" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="genresBtn" text="Genres" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="customersBtn" text="Orders &amp; Library" styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button fx:id="profileBtn" text="Profile &amp; Settings" styleClass="sidebar-btn" maxWidth="Infinity"/>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Separator opacity="0.1" />
            <Button fx:id="deleteProfileBtn" text="Delete Account" styleClass="sidebar-btn" maxWidth="Infinity" style="-fx-text-fill: #FFAAAA;"/>
            <Button fx:id="signOutBtn" text="Sign Out" styleClass="sidebar-btn" maxWidth="Infinity" style="-fx-text-fill: #F35353;"/>
        </VBox>
    </left>

    <!-- Main Dynamic Workspace -->
    <center>
        <StackPane fx:id="contentArea">
            
            <!-- CATALOG VIEW -->
            <VBox fx:id="catalogView" spacing="20.0" styleClass="main-content">
                <!-- Header Actions Area -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Game Catalog" styleClass="page-title"/>
                        <Label text="Manage, update and track available digital titles." styleClass="sub-header-text" wrapText="true"/>
                    </VBox>
                    <!-- Real-time Filters & Search -->
                    <HBox spacing="10.0" alignment="CENTER_RIGHT">
                        <MenuButton fx:id="publisherFilterMenu" text="Publishers" prefWidth="150.0"/>
                        <MenuButton fx:id="genreFilterMenu" text="Genres" prefWidth="150.0"/>
                        <Button fx:id="clearFiltersBtn" text="Clear Filters" style="-fx-background-color: #e4e6eb; -fx-text-fill: #4b4f56; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 5 12 5 12; -fx-cursor: hand;"/>
                        <TextField fx:id="searchField" promptText="Search games by title..." prefWidth="200.0"/>
                        <Button fx:id="addProductBtn" text="+ Add New Product" styleClass="primary-button"/>
                    </HBox>
                </HBox>

                <!-- Featured Carousel Area -->
                <StackPane fx:id="carouselContainer" styleClass="carousel-container" prefHeight="220.0" minHeight="220.0" VBox.vgrow="NEVER">
                    <!-- Dynamic content will be injected by controller -->
                </StackPane>

                <!-- Games Grid Visualization -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 0; -fx-border-color: transparent; -fx-background-insets: 0;">
                    <content>
                        <FlowPane fx:id="gamesFlowPane" hgap="20.0" vgap="20.0" style="-fx-padding: 10;" alignment="TOP_CENTER"/>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- INVENTORY VIEW -->
            <VBox fx:id="inventoryView" spacing="20.0" styleClass="main-content" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Key Inventory" styleClass="page-title"/>
                        <Label text="Manage activation keys and bind them to games." styleClass="sub-header-text" wrapText="true"/>
                    </VBox>
                    <HBox spacing="10.0" alignment="CENTER_RIGHT">
                        <Button fx:id="addKeyBtn" text="+ Stock New Key" styleClass="primary-button"/>
                    </HBox>
                </HBox>

                <TableView fx:id="keysTable" VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="No keys currently in stock." styleClass="sub-header-text"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="keyIdColumn" text="Internal Key UUID" prefWidth="150.0" visible="false"/>
                        <TableColumn fx:id="keyValueColumn" text="Activation Code" prefWidth="220.0" />
                        <TableColumn fx:id="keyGameColumn" text="Target Game" prefWidth="200.0" />
                        <TableColumn fx:id="keyStatusColumn" text="State" prefWidth="100.0" />
                        <TableColumn fx:id="keySoldAtColumn" text="Sold At" prefWidth="150.0" />
                        <TableColumn fx:id="keyBuyerColumn" text="Buyer User" prefWidth="180.0" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
            
            <!-- ORDER LIBRARY VIEW -->
            <VBox fx:id="ordersView" spacing="20.0" visible="false" managed="false" style="-fx-padding: 0 10 0 10;">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Purchase History" styleClass="page-title"/>
                        <Label text="Track acquired games, review transactions, and retrieve serial codes." styleClass="sub-header-text" wrapText="true"/>
                    </VBox>
                    <Button fx:id="exportOrdersBtn" text="📥 Export Log to Excel" styleClass="action-btn" />
                </HBox>
                
                <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="No purchase records located." styleClass="sub-header-text"/>
                    </placeholder>
                    <columns>
                        <TableColumn fx:id="orderDateColumn" text="Date" prefWidth="180.0" />
                        <TableColumn fx:id="orderEmailColumn" text="Customer Email" prefWidth="200.0" />
                        <TableColumn fx:id="orderGameColumn" text="Acquired Title" prefWidth="220.0" />
                        <TableColumn fx:id="orderKeyColumn" text="Activation Key" prefWidth="200.0" />
                        <TableColumn fx:id="orderPriceColumn" text="Total ($)" prefWidth="100.0" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
            
            <!-- PUBLISHERS VIEW -->
            <VBox fx:id="publishersView" spacing="20.0" visible="false" managed="false" style="-fx-padding: 0 10 0 10;">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Publishers Management" styleClass="page-title"/>
                        <Label text="Manage distribution partners and companies." styleClass="sub-header-text" wrapText="true"/>
                    </VBox>
                    <Button fx:id="addPublisherBtn" text="New Publisher" styleClass="action-btn" />
                </HBox>
                <TableView fx:id="publishersTable" VBox.vgrow="ALWAYS">
                    <placeholder><Label text="No publishers registered." styleClass="sub-header-text"/></placeholder>
                    <columns>
                        <TableColumn fx:id="publisherNameCol" text="Company Name" prefWidth="250.0" />
                        <TableColumn fx:id="publisherWebsiteCol" text="Website" prefWidth="250.0" />
                        <TableColumn fx:id="publisherEmailCol" text="Support Email" prefWidth="250.0" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>
            </VBox>

            <!-- GENRES VIEW -->
            <VBox fx:id="genresView" spacing="20.0" visible="false" managed="false" style="-fx-padding: 0 10 0 10;">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Genres Management" styleClass="page-title"/>
                        <Label text="Manage catalog categorizations." styleClass="sub-header-text" wrapText="true"/>
                    </VBox>
                    <Button fx:id="addGenreBtn" text="New Genre" styleClass="action-btn" />
                </HBox>
                <TableView fx:id="genresTable" VBox.vgrow="ALWAYS">
                    <placeholder><Label text="No genres registered." styleClass="sub-header-text"/></placeholder>
                    <columns>
                        <TableColumn fx:id="genreNameCol" text="Genre Name" prefWidth="750.0" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>
            </VBox>

            <!-- PROFILE & SETTINGS VIEW -->
            <VBox fx:id="profileView" spacing="20.0" visible="false" managed="false" styleClass="main-content">
                <VBox spacing="5">
                    <Label text="My Profile &amp; Settings" styleClass="page-title"/>
                    <Label text="Manage your security preferences and store balance." styleClass="sub-header-text" wrapText="true"/>
                </VBox>
                
                <Separator opacity="0.2"/>
                
                <VBox spacing="15" styleClass="login-panel" maxWidth="500.0" alignment="CENTER_LEFT">
                    <Label text="Account Information" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    
                    <GridPane hgap="15" vgap="10">
                        <Label text="Public Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="profileNameLabel" text="[Name]" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Label text="Email Address:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                        <Label fx:id="profileEmailLabel" text="[Email]" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Label text="Account Role:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                        <Label fx:id="profileRoleLabel" text="[Role]" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Store Balance:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
                        <Label fx:id="profileBalanceLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
                    </GridPane>
                    
                    <Separator opacity="0.2"/>
                    
                    <Label fx:id="securitySettingsHeader" text="Security Settings" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <CheckBox fx:id="twoFactorCheckbox" text="Enable Two-Factor Authentication (2FA) via Email" style="-fx-cursor: hand;"/>
                    <Label fx:id="twoFactorDescLabel" text="If enabled, a 6-digit confirmation code will be required during login." style="-fx-font-size: 11px; -fx-text-fill: #777;"/>
                    
                    <Separator opacity="0.2" fx:id="profileBalanceSeparator"/>
                    <Label fx:id="profileBalanceHeader" text="Wallet Balance" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Button fx:id="topUpBalanceBtn" text="Top Up Balance" styleClass="primary-button" maxWidth="200.0"/>
                </VBox>
            </VBox>
            
        </StackPane>

    </center>

</BorderPane>
